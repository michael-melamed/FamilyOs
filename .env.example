# Supabase Configuration
# Get from: supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_[YOUR_ANON_KEY]

# Service Role Key for initial family creation (NEVER EXPOSE TO CLIENT)
# Get from: supabase.com -> Project Settings -> API (service_role secret)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_[YOUR_SERVICE_ROLE_KEY]

# Anthropic Configuration
# Get from: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-api03-[YOUR_ANTHROPIC_KEY]

# App Base URL (usually http://localhost:3000 for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
